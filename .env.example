# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (in the repo root) and fill in GROQ_API_KEY.
#   cp .env.example .env
# `.env` is gitignored. Never commit a real key.
# ─────────────────────────────────────────────────────────────────────────────

# Create a token at https://console.groq.com/keys (the assignment says to make a new one).
GROQ_API_KEY=gsk_replace_me

# ── Model selection ──────────────────────────────────────────────────────────
# Tool-calling agent. Production tier on Groq, no deprecation notice, supports tool
# use + strict json_schema, 131,072 ctx. Verified against
# https://console.groq.com/docs/deprecations on 2026-07-15.
GROQ_AGENT_MODEL=openai/gpt-oss-120b

# Cheap constrained-extraction node (structured outputs / the extract_fallback path).
# Separate free-tier token bucket. Also the honest heir to the spec's gemma2 intent:
# small, fast, open-weights.
GROQ_EXTRACT_MODEL=openai/gpt-oss-20b

# ── The spec's two named models. Both handled, both dated. ───────────────────
# Uncomment either to see the app's handling. See README § "Model mandate".
# GROQ_AGENT_MODEL=gemma2-9b-it              # spec model #1. 404s since 2025-10-08.
#                                            # preflight_model() catches it -> routes to gpt-oss-20b.
# GROQ_AGENT_MODEL=llama-3.3-70b-versatile   # spec model #2. Works today. Groq shutdown 2026-08-16.

# ── Database ─────────────────────────────────────────────────────────────────
# Matches docker-compose.yml. For a local (non-Docker) Postgres, point this at it.
DATABASE_URL=postgresql://app_user:app@localhost:5432/repsense

# ── Server ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
